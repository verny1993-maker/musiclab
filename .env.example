# MusicLab — Environment Variables
# Copy to .env and fill in your values
# .env is gitignored — never commit real tokens

# Discogs API (https://www.discogs.com/settings/developers)
DISCOGS_TOKEN=

# Last.fm API (https://www.last.fm/api/account/create)
LASTFM_API_KEY=

# Spotify Web API (https://developer.spotify.com/dashboard)
SPOTIFY_ACCESS_TOKEN=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# MusicBrainz user agent (app name + contact email)
MB_USER_AGENT=MusicLab/0.1 ( your@email.com )
